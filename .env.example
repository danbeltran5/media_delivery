# Local Postgres (via Homebrew: brew services start postgresql@16). For
# production, replace with a real Postgres connection string (Neon, Supabase,
# Vercel Postgres, etc.)
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Cloudflare Stream (video hosting) — https://dash.cloudflare.com -> Stream
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_STREAM_API_TOKEN=""
# Dashboard -> Stream -> any video -> "Customer code" in the embed/player URL
# (looks like: customer-XXXXXXXXXXXX)
CLOUDFLARE_STREAM_CUSTOMER_CODE=""

# Dropbox — https://www.dropbox.com/developers/apps
# Only needed for scripts/link-existing-videos.ts (see README)
DROPBOX_ACCESS_TOKEN=""

# Admin dashboard (/admin) — pick your own password
ADMIN_PASSWORD=""

# Stripe — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# From `stripe listen` locally, or the webhook endpoint's signing secret in prod
STRIPE_WEBHOOK_SECRET=""

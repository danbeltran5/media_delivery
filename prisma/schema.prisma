// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Client {
  id              String   @id @default(cuid())
  slug            String   @unique
  name            String
  tagline         String?
  orientation     String   @default("portrait") // portrait | landscape
  watermark       Boolean  @default(true)
  showAccessForm  Boolean  @default(true)
  requirePurchase Boolean  @default(true) // false = plain one-click Download, no cart/Stripe
  createdAt       DateTime @default(now())
  videos          Video[]
  credits         Credit[]
}

model Credit {
  id           String     @id @default(cuid())
  clientId     String
  client       Client     @relation(fields: [clientId], references: [id])
  email        String
  totalCredits Int
  createdAt    DateTime   @default(now())
  purchases    Purchase[]

  @@unique([clientId, email])
}

model Video {
  id           String     @id @default(cuid())
  clientId     String
  client       Client     @relation(fields: [clientId], references: [id])
  title        String
  description  String?
  cfStreamUid  String     @unique
  downloadUrl  String
  thumbnailSec Int        @default(0) // seconds into the video to pull the thumbnail frame from
  priceCents   Int
  currency     String     @default("usd")
  createdAt    DateTime   @default(now())
  purchases    Purchase[]
}

model Purchase {
  id              String    @id @default(cuid())
  videoId         String
  video           Video     @relation(fields: [videoId], references: [id])
  stripeSessionId String?
  creditId        String?
  credit          Credit?   @relation(fields: [creditId], references: [id])
  status          String    @default("pending") // pending | paid
  amountCents     Int
  email           String?
  createdAt       DateTime  @default(now())
  downloadedAt    DateTime?

  @@unique([videoId, stripeSessionId])
  @@index([stripeSessionId])
  @@index([creditId])
}
